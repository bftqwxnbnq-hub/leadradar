{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "legal.html", "use": "@vercel/static" },
    { "src": "account.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/legal", "dest": "/legal.html" },
    { "src": "/account", "dest": "/account.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
